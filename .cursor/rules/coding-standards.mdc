## Client-Side Data Patterns

This project does NOT use a server-side database. All persistence is browser-native:

### IndexedDB (History / Audio Metadata)

\\\	sx
// src/lib/storage/history.ts
import { openDB, type IDBPDatabase } from "idb";

interface HistoryItem {
  id: string;
  text: string;
  voice: string;
  speed: number;
  duration: number;
  audioUrl: string;
  createdAt: number;
}

const db = await openDB<{ history: HistoryItem }>("tts-db", 1, {
  upgrade(db) {
    db.createObjectStore("history", { keyPath: "id" });
  },
});

// CRUD operations â€” follow this pattern
export async function getHistory(): Promise<HistoryItem[]> {
  return db.getAll("history");
}
\\\

### localStorage (Settings)

\\\	sx
// Persisted via Zustand persist middleware â€” no direct localStorage calls needed
import { create } from "zustand";
import { persist } from "zustand/middleware";

export const useTtsStore = create(
  persist(
    (set) => ({
      settings: { voice: "default", speed: 1 },
      setSettings: (newSettings) =>
        set((state) => ({ settings: { ...state.settings, ...newSettings } })),
    }),
    { name: "tts-settings" },
  ),
);
\\\

### R2 (TTS Models)

Models are downloaded lazily from Cloudflare R2 via signed URLs â€” no local file storage:

\\\	sx
// Only load from allowed R2 paths
const ALLOWED_MODEL_PREFIXES = ["piper/vi/", "piper/en/"];

function isAllowedModelPath(path: string): boolean {
  return ALLOWED_MODEL_PREFIXES.some((prefix) => path.startsWith(prefix));
}
